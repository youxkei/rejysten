{
  "name": "rejysten",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint src/**/*.{ts,tsx}",
    "fix": "pnpm run lint --fix; prettier --write src/**/*.{ts,tsx}",
    "build": "vite build",
    "dev": "vite",
    "tsc": "tsc --noEmit",
    "test": "pnpm tsc && pnpm test/nocheck",
    "test/case": "node scripts/test-case.mjs",
    "test/nocheck": "vitest run -c vitest.config.functions.ts && vitest run -c vitest.config.firestore-rules.ts && vitest run",
    "prepare": "git config --local core.hooksPath .githooks",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "emulator:run": "firebase emulators:start --only firestore --config firebase.local.json --project demo",
    "emulator:clear": "curl -X DELETE 'http://localhost:8080/emulator/v1/projects/demo/databases/(default)/documents'",
    "test:functions": "vitest run -c vitest.config.functions.ts",
    "test:firestore-rules": "vitest run -c vitest.config.firestore-rules.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youxkei/rejysten.git"
  },
  "author": "Hisayuki Mima <youxkei@gmail.com>",
  "license": "CC0-1.0",
  "bugs": {
    "url": "https://github.com/youxkei/rejysten/issues"
  },
  "homepage": "https://github.com/youxkei/rejysten#readme",
  "type": "module",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@cloudflare/workers-types": "^4.20260605.1",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/js-yaml": "^4.0.9",
    "@types/moji": "^0.5.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitest/browser-playwright": "^4.1.8",
    "babel-preset-solid": "^1.9.12",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "firebase-tools": "^15.19.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.4.2",
    "storybook-solidjs-vite": "^10.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-checker": "^0.6.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.98.0"
  },
  "dependencies": {
    "@solid-primitives/context": "^0.2.3",
    "@solid-primitives/keyed": "^1.5.3",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solid-primitives/storage": "^3.8.0",
    "@vanilla-extract/css": "^1.20.1",
    "fast-deep-equal": "^3.1.3",
    "firebase": "^11.10.0",
    "fractional-indexing": "^3.2.0",
    "immer": "^10.2.0",
    "js-yaml": "^4.2.0",
    "moji": "^0.5.1",
    "solid-js": "^1.9.13",
    "superstruct": "^1.0.4",
    "uuidv7": "^1.2.1",
    "xregexp": "^5.1.2"
  },
  "prettier": {
    "printWidth": 120
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "vite": "8",
        "esbuild": ">=0.25.0"
      }
    }
  }
}
